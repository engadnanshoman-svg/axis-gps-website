pages/custom/login/login-general.js?v=7.0.4\" type=\"text/javascript\"></script>\n<!--end::Page Scripts-->\n\n<script src=\"https://axispal.blue.ps/public/assets/plugins/custom/jquery-validation/dist/jquery.validate.js\" type=\"text/javascript\"></script>\n<script src=\"https://axispal.blue.ps/public/assets/plugins/custom/jquery-validation/dist/additional-methods.js\" type=\"text/javascript\"></script>\n\n<script>\n\tvar login = $('#kt_login');\n\t$.ajaxSetup({\n\t\theaders: {'X-CSRF-TOKEN': $('meta[name=\"csrf-token\"]').attr('content')}\n\t});\n\t$(document).ready(function() {\n\n\t\t$(document).on('click', '#kt_login_forgot', function (e) {\n\t\t\t$(\"#login-signin\").slideUp(500);\n\t\t\t$(\"#login-forgot\").slideDown(1000);\n\t\t});\n\n\t\t$(document).on('click', '#kt_login_forgot_cancel', function (e) {\n\t\t\t$(\"#login-forgot\").slideUp(500);\n\t\t\t$(\"#login-signin\").slideDown(1000);\n\t\t});\n\n\n\t\t$('#kt_login_signin_submit_1').click(function(e) {\n\t\t\te.preventDefault();\n\t\t\tvar btn = $(this);\n\t\t\tvar form = $('#kt_login_signin_form');\n\n\t\t\tform.validate({\n\t\t\t\trules: {\n\t\t\t\t\ts_email: {\n\t\t\t\t\t\trequired: true,\n\t\t\t\t\t\temail: true\n\t\t\t\t\t},\n\t\t\t\t\ts_password: {\n\t\t\t\t\t\trequired: true\n\t\t\t\t\t}\n\t\t\t\t},\n\t\t\t\tmessages: {\n\t\t\t\t\ts_password: {\n\t\t\t\t\t\trequired: 'هذا الحقل مطلوب',\n\t\t\t\t\t},\n\t\t\t\t\ts_email: {\n\t\t\t\t\t\trequired: 'هذا الحقل مطلوب',\n\t\t\t\t\t\temail: 'هذا الحقل يجب ان يحتوي على بريد الكتروني صحيح',\n\t\t\t\t\t},\n\n\t\t\t\t},\n\n\t\t\t});\n\n\t\t\tif (!form.valid()) return;\n\t\t\tvar data = form.serializeArray();\n\t\t\tbtn.attr('disabled', true);\n\t\t\t$.ajax({\n\t\t\t\turl: 'https://axispal.blue.ps/admin/login',\n\t\t\t\tdata : data,\n\t\t\t\ttype: 'POST',\n\t\t\t\tsuccess: function(response, status, xhr, $form) {\n\t\t\t\t\t// similate 2s delay\n\n\t\t\t\t\tvar login_status = response.login_status;\n\t\t\t\t\tvar message = response.message;\n\t\t\t\t\tvar redirec