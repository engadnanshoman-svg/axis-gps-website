# ══════════════════════════════════════════════════════════
# إعدادات إرسال البريد الإلكتروني - نموذج الاتصال
# الإيميلات تصل إلى: adnan@axis-gps.com فقط
# ══════════════════════════════════════════════════════════

# الخيار 1: Resend API (الأساسي)
# احصل على مفتاح مجاني من https://resend.com
# سجّل الدخول وأنشئ API Key ثم ضعه هنا
RESEND_API_KEY=

# الخيار 2: SMTP (البديل)
# إذا لم يكن مفتاح Resend متاحاً، استخدم إعدادات SMTP
# مثال لإعدادات Gmail:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
#
# مثال لإعدادات Outlook/Hotmail:
# SMTP_HOST=smtp-mail.outlook.com
# SMTP_PORT=587
# SMTP_USER=your-email@outlook.com
# SMTP_PASS=your-password
#
# مثال لإعدادات استضافة مخصصة:
# SMTP_HOST=mail.axis-gps.com
# SMTP_PORT=465
# SMTP_USER=info@axis-gps.com
# SMTP_PASS=your-password
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
